            "text": "<!DOCTYPE html>\n<html xmlns=\"http://www.w3.org/1999/xhtml\">\n<head>\n    <title><<PII_NAME_65052276>></title>\n    <link rel=\"stylesheet\" type=\"text/css\" href=\"/Web<<INTERNAL_URL_ac68bd93>>/css/main.css\"/>\n    <link rel=\"stylesheet\" type=\"text/css\" href=\"/Web<<INTERNAL_URL_ac68bd93>>/plugins/<<PII_HANDLE_333c04dd>>/css/<<PII_HANDLE_333c04dd>>.min.css\"/>\n    <link rel=\"stylesheet\" type=\"text/css\" href=\"/Web<<INTERNAL_URL_ac68bd93>>/css/font-awesome.min.css\"/>\n    <link rel=\"stylesheet\" type=\"text/css\" href=\"/Web<<INTERNAL_URL_ac68bd93>>/css/animate.css\"/>\n</head>\n<body>\n<section id=\"container\">\n    <header id=\"header\">\n        <div class=\"brand\">\n            <a href=\"/Web<<INTERNAL_URL_ac68bd93>>/start.mvc\" class=\"logo\"><span>Web</span><<INTERNAL_URL_ac68bd93>></a>\n        </div>\n        <div class=\"lessonTitle\">\n        </div>\n\n    </header>\n    <section class=\"main-content-wrapper\">\n\n        <section id=\"main-content\">\n            <br/><br/>\n            <fieldset>\n                <legend>Register</legend>\n                <form class=\"form-horizontal\" action=\"/Web<<INTERNAL_URL_ac68bd93>>/register.mvc\" method='POST'>\n\n                    <div class=\"form-group\">\n                        <label for=\"username\" class=\"col-sm-2 control-label\">Username</label>\n                        <div class=\"col-sm-4\">\n                            <input autofocus=\"dummy_for_thymeleaf_parser\" type=\"text\" class=\"form-control\"\n                                   id=\"username\" placeholder=\"Username\" name='username' value=\"\"/>\n                        </div>\n                        \n                    </div>\n                    <div class=\"form-group\">\n                        <label for=\"password\" class=\"col-sm-2 control-label\">Password</label>\n                        <div class=\"col-sm-4\">\n                            <input type=\"password\" class=\"form-control